{
  "name": "mrloh.io",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@atproto/api": "^0.15.8",
    "@formatjs/intl-durationformat": "^0.10.13",
    "@headlessui/react": "^2.2.0",
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "^16.2.6",
    "@types/mdx": "^2.0.13",
    "@vercel/analytics": "^1.4.1",
    "client-only": "^0.0.1",
    "feed": "^5.0.1",
    "lucide-react": "^0.469.0",
    "next": "16.2.6",
    "next-themes": "^0.4.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rehype-react": "^8.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-mdx-frontmatter": "^5.0.0",
    "remark-rehype": "^11.1.2",
    "server-only": "^0.0.1",
    "shiki": "^4.0.2",
    "tailwind-merge": "^2.6.0",
    "temporal-polyfill-lite": "^0.4.0",
    "ts-pattern": "^5.6.0",
    "yaml": "^2.9.0",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.4.0",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/postcss": "4.0.0-beta.8",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^20",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "postcss": "^8",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "4.0.0-beta.8",
    "typescript": "^5"
  },
  "prettier": {
    "singleQuote": true,
    "printWidth": 100,
    "objectWrap": "collapse",
    "quoteProps": "consistent",
    "plugins": [
      "@ianvs/prettier-plugin-sort-imports",
      "prettier-plugin-tailwindcss"
    ],
    "importOrder": [
      "<BUILTIN_MODULES>",
      "<THIRD_PARTY_MODULES>",
      "",
      "^@/(.*)$",
      "",
      "^[./]"
    ],
    "tailwindFunctions": [
      "clsx",
      "cn",
      "twMerge",
      "twJoin"
    ]
  },
  "postcss": {
    "plugins": {
      "@tailwindcss/postcss": {}
    }
  }
}
